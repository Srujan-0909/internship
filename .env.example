# ── InternPilot Environment Variables ──────────────────────────────────────────
#
# Copy this file to .env and fill in your keys.
# NEVER commit .env to git.

# Anthropic — for AI cover letter generation
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# JSearch (via RapidAPI) — aggregates LinkedIn, Indeed, Glassdoor, Ziprecruiter
# Free tier: 200 requests/month
# Sign up at: https://rapidapi.com/ → search "JSearch by letscrape" → Subscribe (Free)
JSEARCH_API_KEY=your_rapidapi_key_here

# Optional: change the API port (default: 3001)
# PORT=3001
